{
  "name": "expense-tracker",
  "version": "1.3.0-beta.1",
  "description": "Local expense tracker for company card statements. Fully offline.",
  "main": "./out/main/index.js",
  "author": {
    "name": "UNIMEX"
  },
  "copyright": "Copyright © 2026 UNIMEX",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "rebuild": "cd node_modules/better-sqlite3 && npx prebuild-install -r electron -t 41.7.2",
    "postinstall": "npm run rebuild",
    "selftest": "npm run build && electron . --selftest",
    "dist": "electron-vite build && electron-builder --win",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "release": "electron-vite build && electron-builder --win --publish always",
    "release:mac": "electron-vite build && electron-builder --mac --publish always"
  },
  "build": {
    "appId": "com.unimex.expense-tracker",
    "productName": "Expense Tracker",
    "npmRebuild": false,
    "detectUpdateChannel": false,
    "files": [
      "out/**"
    ],
    "nsis": {
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Expense Tracker"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "category": "public.app-category.finance",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "andytorresjr",
        "repo": "expense-tracker"
      }
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.8.9",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "5.4.296",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "electron": "^41.7.2",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  }
}
